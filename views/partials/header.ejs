<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Дневник путешествий</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="topbar">
    <a class="brand" href="/travels">✈ Дневник путешествий</a>
    <nav>
      <% if (currentUser) { %>
        <a href="/travels">Все путешествия</a>
        <a href="/travels/mine">Мои записи</a>
        <a href="/travels/new">+ Новая запись</a>
        <span class="muted" style="color:#dff2ee;"><%= currentUser.username %></span>
        <form action="/logout?_method=POST" method="POST">
          <button class="linklike" type="submit">Выйти</button>
        </form>
      <% } else { %>
        <a href="/login">Войти</a>
        <a href="/register">Регистрация</a>
      <% } %>
    </nav>
  </div>
  <div class="container">
