<%- include('../partials/header') %>

<h1 class="page-title">Мои записи</h1>

<% if (travels.length === 0) { %>
  <div class="empty-state">
    <p>Вы ещё не добавили ни одного путешествия.</p>
    <a class="btn" href="/travels/new">Добавить путешествие</a>
  </div>
<% } else { %>
  <div class="travel-grid">
    <% travels.forEach(t => { %>
      <a class="card travel-card" href="/travels/<%= t._id %>">
        <% if (t.images && t.images.length) { %>
          <img src="<%= t.images[0] %>" alt="<%= t.title %>">
        <% } %>
        <h3><%= t.title %></h3>
        <div class="tag-row">
          <span class="tag">📍 <%= t.location.name %></span>
          <span class="tag">💰 <%= t.cost %> ₽</span>
        </div>
      </a>
    <% }) %>
  </div>
<% } %>

<%- include('../partials/footer') %>
